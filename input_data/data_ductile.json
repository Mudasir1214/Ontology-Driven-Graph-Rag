      "id": "R-DI-DIP-COAT-001",
      "labels": ["Rule"],
      "properties": {
        "id": "R-DI-DIP-COAT-001",
        "text": "For ductile iron pipes and fittings to BS EN 598:2007 (sewer drainage), internal coating shall be HAC mortar and external coating shall be zinc plus resin.",
        "page_number": null
      }
    },
    {
      "id": "R-PI-DIP-COAT-001",
      "labels": ["Rule"],
      "properties": {
        "id": "R-PI-DIP-COAT-001",
        "text": "For ductile iron pipes, joints and fittings to BS EN 545:2010 Class 100, internal cement lining and external bitumen coating are required.",
        "page_number": null
      }
    },
    {
      "id": "R-FS-DIP-COAT-001",
      "labels": ["Rule"],
      "properties": {
        "id": "R-FS-DIP-COAT-001",
        "text": "For underground pipework to BS EN 545:2002 Class K12, external zinc coating of 130 g/m² with purity not less than 99.9% is required for ductile iron pipes.",
        "page_number": null
      }
    },

