    "rule": {
      "id": "R-MECH-6.2.8-ACOUSTIC-DUCTLAG-001",
      "text": "Acoustic duct lag: 50 mm thick glass fibre/lead sheet OR barium-loaded vinyl sheet/glass fibre, with a factory-applied aluminium vapour-barrier jacket used also for thermal insulation. Fibreglass density 24 kg/m³ and thermal conductivity ≤ 0.032 W/m·°C. Lead sheet surface weight 5 kg/m².",
      "page_number": null,
      "document_id": "DOC-BSI-2022",
      "chapter_id": "CH-06-2-8",
      "module_id": "MOD-Mechanical"
    },
    "component": {
      "id": "C-IfcDuctLag-Acoustic",
      "name": "Acoustic duct lag / insulation",
      "ifc_class": "IfcMaterialLayer"
    },
    "material": [
      {
        "id": "M-GLASSFIBRE-24-032",
        "name": "Glass fibre (acoustic)",
        "standard": null,
        "attributes": {
          "density_kg_m3": 24,
          "thermal_conductivity_w_m_k_max": 0.032,
          "thickness_mm": 50,
          "application": "acoustic duct lag"
        }
      },
      {
        "id": "M-LEADSHEET-5",
        "name": "Lead sheet (surface-weighted)",
        "standard": null,
        "attributes": {
          "surface_weight_kg_m2": 5,
          "application": "acoustic duct lag (paired with glass fibre)"
        }
      },
      {
        "id": "M-BARIUMVINYL-GLASSFIBRE",
        "name": "Barium-loaded vinyl sheet + glass fibre",
        "standard": null,
        "attributes": {
          "thickness_mm": 50,
          "application": "acoustic duct lag (barium-loaded vinyl sheet combined with glass fibre)"
        }
      },
      {
        "id": "M-AL-VAPOUR-JACKET",
        "name": "Factory-applied aluminium vapour-barrier jacket",
        "standard": null,
        "attributes": {
          "function": [
            "vapour barrier",
            "thermal insulation jacket"
          ],
          "application": "used over duct lag"
        }
      }
    ],
    "constraintGroups": [
