    "rule": {
      "id": "R-FP-APP8-010",
      "text": "Appendix 8, Item 10: \"Emergency generators - Power supply cables (from emergency generator to main switchboard)\" shall conform with (a) BS 6387 Cat. CWZ; or (b) BS 6207 or BS EN 60702; or (c) other international standards acceptable. No PH rating or survival-time requirement is stated in this item.",
      "page_number": null,
      "document_id": "DOC-FireCodes-2012",
      "chapter_id": "APP-08",
      "module_id": "MOD-FireProtection"
    },
