      "name": "Emergency generator power supply cable",
      "standard": null,
      "attributes": {
        "application": "Power supply cable from emergency generator to main switchboard",
        "notes": "Item 10 (2012): standards listed; no PH rating or explicit survival-time requirement stated."
      }
    },
