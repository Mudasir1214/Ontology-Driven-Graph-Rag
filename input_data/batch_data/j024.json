    "constraintGroups": [
      {
        "Id": "CG-MECH-COPPER-JOINTS-MAIN",
        "Rule_id": "R-MECH-COPPER-JOINTS-2024",
        "Logic": "OR",
        "description": "Permitted jointing methods for copper pipe: flanged OR flared (conditional) OR brazed (with/without capillary fittings).",
        "constraints": [
          "C-MECH-COPPER-JOINT-FLANGED",
          "C-MECH-COPPER-JOINT-FLARED-COND",
          "C-MECH-COPPER-JOINT-BRAZED"
        ]
      },
      {
        "Id": "CG-MECH-COPPER-FLARE-APPL",
        "Rule_id": "R-MECH-COPPER-JOINTS-2024",
        "Logic": "CONDITIONAL",
        "description": "Flare applicability branch: allowed only when pipe outside diameter ≤ 20 mm.",
        "condition": "pipe_outside_diameter_mm",
        "branches": [
          {
            "condition_expression": "<= 20",
            "applies_constraints": [
              "C-MECH-COPPER-JOINT-FLARED"
            ]
          },
          {
            "condition_expression": "> 20",
            "applies_constraints": [
              "C-MECH-COPPER-JOINT-FLARED-DISALLOWED"
            ]
          }
        ]
      }
    ],
    "constraints": [
      {
        "Id": "C-MECH-COPPER-JOINT-FLANGED",
        "Type": "joint_type",
        "Operator": "=",
        "Value": "flanged",
        "Unit": null,
        "Tolerance": null,
        "note": "Flanged joints are an acceptable jointing method for copper pipe (no diameter restriction stated)."
      },
      {
        "Id": "C-MECH-COPPER-JOINT-FLARED-COND",
        "Type": "conditional_application",
        "Operator": "conditional",
        "Value": "flared_allowed_if_diameter_<=_20",
        "Unit": null,
        "Tolerance": null,
        "note": "Flared joints are permitted only for pipe outside diameter up to 20 mm."
      },
      {
        "Id": "C-MECH-COPPER-JOINT-FLARED",
        "Type": "joint_type",
        "Operator": "=",
        "Value": "flared",
        "Unit": null,
        "Tolerance": null,
        "note": "Flared joint (valid when OD ≤ 20 mm)."
      },
      {
        "Id": "C-MECH-COPPER-JOINT-FLARED-DISALLOWED",
        "Type": "joint_type_restriction",
        "Operator": "=",
        "Value": "flared_disallowed",
        "Unit": null,
        "Tolerance": null,
        "note": "Flared joints are not allowed when pipe OD > 20 mm."
      },
      {
        "Id": "C-MECH-COPPER-JOINT-BRAZED",
        "Type": "joint_type",
        "Operator": "=",
        "Value": "brazed",
        "Unit": null,
        "Tolerance": null,
        "note": "Brazing is permitted; may be performed with or without capillary fittings."
      },
      {
        "Id": "C-MECH-COPPER-BRAZE-CAPILLARY-OPTION",
        "Type": "assembly_option",
        "Operator": "in",
        "Value": [
          "with_capillary_fittings",
          "without_capillary_fittings"
        ],
        "Unit": null,
        "Tolerance": null,
        "note": "Brazed joints may use capillary fittings or be brazed without capillary fittings."
      },
      {
        "Id": "C-MECH-COPPER-FLARE-THRESH",
        "Type": "dimension_threshold",
        "Operator": "=",
        "Value": 20,
        "Unit": "mm",
        "Tolerance": null,
        "note": "Outside diameter threshold for allowing flared joints."
      }
