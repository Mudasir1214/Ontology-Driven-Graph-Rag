        "Type": "system_voltage",
        "Operator": "=",
        "Value": 11,
        "Unit": "kV",
        "Tolerance": null,
        "note": "System voltage option: 11 kV."
      },
      {
        "Id": "C-EL-AUTOTR-FREQ",
