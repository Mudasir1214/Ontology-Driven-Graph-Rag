        "note": "Connections: auto-star for auto-transformer starting."
      },
      {
        "Id": "C-EL-AUTOTR-INSLVL",
        "Type": "insulation_level",
        "Operator": "=",
        "Value": 45,
        "Unit": "kV_peak_impulse_1/50µs",
        "Tolerance": null,
        "note": "Insulation level: 45 kV peak impulse voltage for 1/50 microsecond."
      },
      {
        "Id": "C-EL-AUTOTR-COOLING",
        "Type": "cooling_method",
        "Operator": "=",
        "Value": "natural_air_cooled",
        "Unit": null,
        "Tolerance": null,
        "note": "Cooling: natural air cooled."
      },
      {
