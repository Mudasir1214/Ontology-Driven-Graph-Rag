    },
    "chapter": {
      "id": "CH-07-2-13",
      "title": "7.2.13 – High Voltage Switchgear and Equipment"
    },
    "module": {
      "id": "MOD-Electrical",
      "name": "Electrical Services"
    },
    "rule": {
      "id": "R-EL-7.2.13-AUTO-TR-2022",
      "text": "Auto-transformers for auto-transformer motor starters shall be indoor, floor-mounted type for no-breaking starting of squirrel-cage 3-phase induction motors; comply with IEC 62271-106; system voltage 3.3 kV, 6.6 kV or 11 kV as specified; frequency 50 Hz; connections: auto-star for auto-transformer starting; insulation level: 45 kV peak impulse voltage (1/50 µs); cooling: natural air cooled; tappings: off-load tap changers with 60%, 75% and 85% of line voltage to limit starting current to 2.5× full load current.",
      "page_number": null,
      "document_id": "DOC-BSI-2022",
      "chapter_id": "CH-07-2-13",
      "module_id": "MOD-Electrical"
    },
    "component": {
      "id": "C-IfcTransformer-Auto",
      "name": "Auto-transformer (motor starter)",
      "ifc_class": "IfcTransformer"
    },
    "material": [],
    "constraintGroups": [
      {
        "Id": "CG-EL-AUTOTR-GENERAL",
        "Rule_id": "R-EL-7.2.13-AUTO-TR-2022",
        "Logic": "AND",
        "description": "General requirements that must all be satisfied for auto-transformers.",
        "constraints": [
          "C-EL-AUTOTR-TYPE",
          "C-EL-AUTOTR-STANDARD",
          "C-EL-AUTOTR-FREQ",
          "C-EL-AUTOTR-CONN",
