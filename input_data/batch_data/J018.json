        "Logic": "IN",
        "description": "Permitted system voltages (one of the specified values).",
        "constraints": [
          "C-EL-AUTOTR-VOLT-3.3",
          "C-EL-AUTOTR-VOLT-6.6",
          "C-EL-AUTOTR-VOLT-11"
        ]
      }
    ],
    "constraints": [
      {
        "Id": "C-EL-AUTOTR-TYPE",
        "Type": "equipment_type",
        "Operator": "=",
