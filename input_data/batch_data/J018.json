        "Type": "starting_current_limit",
        "Operator": "<=",
        "Value": 2.5,
        "Unit": "× full_load_current",
        "Tolerance": null,
        "note": "Starting current limited to 2.5 times full load current when using specified tappings."
      }
    ],
