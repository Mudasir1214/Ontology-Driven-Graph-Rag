    },
    "rule": {
      "id": "R-MECH-CEILFAN-HEIGHT-2022",
      "text": "Unless otherwise stated, ceiling fans shall be mounted no lower than 2400 mm and no higher than 2600 mm from finished floor levels. Down rod lengths shall be sized to meet these requirements.",
      "page_number": null,
      "document_id": "DOC-BSI-2022",
      "chapter_id": "CH-06-CEILING-FAN",
      "module_id": "MOD-Mechanical"
    },
    "component": {
      "id": "C-IfcCeilingFan-001",
      "name": "Ceiling Fan",
      "ifc_class": "IfcFan"
    },
    "component_related": [
      {
        "id": "C-IfcDownRod-001",
        "name": "Ceiling Fan Down Rod",
        "ifc_class": "IfcMechanicalFastener"
      }
    ],
    "material": [],
    "constraintGroups": [
      {
        "Id": "CG-MECH-CEILFAN-HEIGHT",
        "Rule_id": "R-MECH-CEILFAN-HEIGHT-2022",
        "Logic": "AND",
        "description": "Mounting height constraints for ceiling fan installation.",
        "constraints": [
          "C-MECH-CEILFAN-HEIGHT-MIN",
          "C-MECH-CEILFAN-HEIGHT-MAX"
        ]
      },
      {
        "Id": "CG-MECH-CEILFAN-DOWNROD",
        "Rule_id": "R-MECH-CEILFAN-HEIGHT-2022",
        "Logic": "DERIVED",
        "description": "Down rod must be sized to achieve fan mounting height within 2400–2600 mm.",
        "constraints": [
          "C-MECH-CEILFAN-DOWNROD-SIZED"
        ]
      }
    ],
    "constraints": [
      {
        "Id": "C-MECH-CEILFAN-HEIGHT-MIN",
        "Type": "installation_height",
        "Operator": ">=",
        "Value": 2400,
        "Unit": "mm",
        "Tolerance": null,
        "note": "Ceiling fan must be installed at least 2400 mm above finished floor level."
      },
      {
        "Id": "C-MECH-CEILFAN-HEIGHT-MAX",
        "Type": "installation_height",
        "Operator": "<=",
        "Value": 2600,
        "Unit": "mm",
        "Tolerance": null,
        "note": "Ceiling fan must be installed no higher than 2600 mm above finished floor level."
      },
      {
        "Id": "C-MECH-CEILFAN-DOWNROD-SIZED",
        "Type": "component_sizing_requirement",
        "Operator": "=",
        "Value": "down_rod_length_selected_to_meet_height_range",
        "Unit": null,
        "Tolerance": null,
        "note": "Down rod length must be selected to ensure the fan mounting height stays between 2400–2600 mm."
      }
