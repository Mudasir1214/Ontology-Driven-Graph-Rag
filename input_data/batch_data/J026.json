        "Tolerance": null,
        "note": "Non-sheathed copper cables are an acceptable wiring option inside trunking."
      },
      {
        "Id": "C-EL-TRUNKING-SHEATHED",
        "Type": "cable_type",
        "Operator": "=",
        "Value": "sheathed_copper",
        "Unit": null,
        "Tolerance": null,
        "note": "Sheathed copper cables are an acceptable wiring option inside trunking."
      },
      {
        "Id": "C-EL-TRUNKING-3PH-VRATING",
        "Type": "rated_voltage",
        "Operator": ">=",
        "Value": 450,
        "Unit": "V (450/750 V grade or above)",
        "Tolerance": null,
        "note": "Cables serving 3-phase circuits shall be 450/750 V grade or above (minimum grade indicated as 450/750 V)."
      }
    ],
