    "rule": {
      "id": "R-EL-TRUNKING-2026",
      "text": "Wiring system in trunking installation shall consist of non-sheathed copper cables or sheathed copper cables. Cables for 3-phase circuit shall be 450/750 V grade or above.",
      "page_number": null,
      "document_id": "DOC-BSI-2026",
      "chapter_id": "CH-07-WIRING-TRUNKING",
      "module_id": "MOD-Electrical"
    },
    "component": {
      "id": "C-IfcTrunking",
      "name": "Cable trunking (raceway)",
      "ifc_class": "IfcProtectiveDevice" 
    },
    "component_related": [
      {
        "id": "C-IfcCableSegment-NonSheathed",
        "name": "Non-sheathed copper cable",
        "ifc_class": "IfcCableSegment"
      },
      {
        "id": "C-IfcCableSegment-Sheathed",
        "name": "Sheathed copper cable",
        "ifc_class": "IfcCableSegment"
      }
    ],
    "material": [
      {
        "id": "M-COPPER-NON-SHEATHED",
        "name": "Copper conductor (non-sheathed)",
        "standard": null,
        "attributes": {
          "type": "non-sheathed copper cable",
          "application": "wiring in trunking"
        }
      },
      {
        "id": "M-COPPER-SHEATHED",
        "name": "Copper conductor (sheathed)",
        "standard": null,
        "attributes": {
          "type": "sheathed copper cable",
          "application": "wiring in trunking"
        }
      }
    ],
    "constraintGroups": [
      {
        "Id": "CG-EL-TRUNKING-CABLETYPE",
        "Rule_id": "R-EL-TRUNKING-2026",
        "Logic": "OR",
        "description": "Allowed cable composition inside trunking: non-sheathed copper cable OR sheathed copper cable.",
        "constraints": [
          "C-EL-TRUNKING-NON-SHEATHED",
          "C-EL-TRUNKING-SHEATHED"
        ]
      },
      {
        "Id": "CG-EL-TRUNKING-3PH-VOLTAGE",
        "Rule_id": "R-EL-TRUNKING-2026",
        "Logic": "CONDITIONAL",
        "description": "Voltage rating requirement for cables serving 3-phase circuits.",
        "condition": "circuit_type",
        "branches": [
          {
            "condition_expression": "circuit_type == '3-phase'",
            "applies_constraints": [
