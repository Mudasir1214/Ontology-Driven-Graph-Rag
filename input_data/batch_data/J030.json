    { "from": "R-EL-WIREMESH-TRAY-2022", "to": "C-IfcBracket", "type": "APPLIES_TO_COMPONENT" },

    { "from": "R-EL-WIREMESH-TRAY-2022", "to": "CG-EL-WIREMESH-TRAY-SUPPORT-COUNT", "type": "HAS_CONSTRAINT_GROUP" },
    { "from": "R-EL-WIREMESH-TRAY-2022", "to": "CG-EL-WIREMESH-TRAY-FIXING-DIST", "type": "HAS_CONSTRAINT_GROUP" },

    { "from": "CG-EL-WIREMESH-TRAY-SUPPORT-COUNT", "to": "C-EL-WIREMESH-SUPPORT-1", "type": "HAS_CONSTRAINT" },
