    { "from": "CG-EL-TRAY-SUPPORT-COUNT", "to": "C-EL-TRAY-1-SUPPORT", "type": "HAS_CONSTRAINT" },
    { "from": "CG-EL-TRAY-SUPPORT-COUNT", "to": "C-EL-TRAY-2-SUPPORT", "type": "HAS_CONSTRAINT" },

    { "from": "CG-EL-TRAY-MATERIAL", "to": "C-EL-TRAY-MAT-HDG", "type": "HAS_CONSTRAINT" },
