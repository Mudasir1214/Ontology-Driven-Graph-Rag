        "Id": "C-MECH-CCMS-TIMERES-MIN",
        "Type": "time_resolution_min",
        "Operator": ">=",
        "Value": 1,
        "Unit": "minute",
        "Tolerance": null,
        "note": "Minimum selectable cycling time resolution is 1 minute."
      },
      {
        "Id": "C-MECH-CCMS-TIMERES-MAX",
        "Type": "time_resolution_max",
        "Operator": "<=",
        "Value": 120,
        "Unit": "minutes",
        "Tolerance": null,
        "note": "Maximum selectable cycling time resolution is 120 minutes."
      }
