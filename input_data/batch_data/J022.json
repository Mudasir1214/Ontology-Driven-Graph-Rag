      }
    ],
    "constraints": [
      {
        "Id": "C-MECH-CCMS-TIMERES-STEP",
        "Type": "time_resolution_step",
        "Operator": "=",
        "Value": 1,
        "Unit": "minute",
        "Tolerance": null,
        "note": "The CCMS must allow time resolution selectable in 1-minute increments."
