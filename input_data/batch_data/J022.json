        "Id": "CG-MECH-CCMS-TIMERES-2022",
        "Rule_id": "R-MECH-6.1.5-CCMS-TIMERES-2022",
        "Logic": "AND",
        "description": "Time resolution constraints for CCMS cycling period configuration.",
        "constraints": [
          "C-MECH-CCMS-TIMERES-STEP",
          "C-MECH-CCMS-TIMERES-MIN",
          "C-MECH-CCMS-TIMERES-MAX"
